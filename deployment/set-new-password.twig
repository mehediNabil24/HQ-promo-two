{# Keep the designed authentication page full-bleed inside the guest layout. #}
<style>
  body > nav.navbar {
    display: none !important;
  }
</style>

{% if site['resetPassword'] %}
  <div class="sign-in-page">
    <div class="sign-in-layout">
      <div class="sign-in-form-side">
        <div class="sign-in-form-wrapper sign-in-form-wrapper--reset">
          <div class="sign-in-header">
            {% if site['logo'] %}
              <img
                src="{{ site['logo'] }}"
                alt="{{ site['name'] }}"
                width="79"
                height="79"
                class="sign-in-logo"
              />
            {% else %}
              <img
                src="assets/sign-in/logo-light.png"
                alt="{{ site['name']|default('HqPromo') }}"
                width="79"
                height="79"
                class="sign-in-logo sign-in-logo--light"
              />
              <img
                src="assets/sign-in/logo.png"
                alt="{{ site['name']|default('HqPromo') }}"
                width="79"
                height="79"
                class="sign-in-logo sign-in-logo--dark"
              />
            {% endif %}
            <div class="sign-in-header__text">
              <h1 class="sign-in-header__title">Set New Password</h1>
            </div>
          </div>

          <form
            class="sign-in-form{% if site['rtl'] %} rtl-form{% endif %}"
            method="post"
            action=""
            autocomplete="off"
          >
            {% if error %}
              <div class="alert alert-dismissible alert-danger{% if site['rtl'] %} rtl-alert{% endif %}">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                {{ errorMessage }}
              </div>
            {% endif %}

            {% if success %}
              <div class="alert alert-dismissible alert-success{% if site['rtl'] %} rtl-alert{% endif %}">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                {{ successText }}
              </div>
            {% endif %}

            <div class="sign-in-form__fields">
              <div class="sign-in-field">
                <label class="sign-in-field__label" for="username">
                  User Name
                </label>
                <div class="sign-in-field__input-wrap">
                  <img
                    class="sign-in-field__icon si-icon--light"
                    src="assets/sign-in/user-field-light.svg"
                    alt=""
                    width="19"
                    height="19"
                  />
                  <img
                    class="sign-in-field__icon si-icon--dark"
                    src="assets/sign-in/user-field.svg"
                    alt=""
                    width="19"
                    height="19"
                  />
                  <input
                    class="sign-in-field__input"
                    type="text"
                    id="username"
                    value="{{ user['username'] }}"
                    placeholder="user name"
                    autocomplete="username"
                    readonly
                  />
                </div>
              </div>

              <div class="sign-in-field-row">
                <div class="sign-in-field">
                  <label class="sign-in-field__label" for="password_new">
                    Password
                  </label>
                  <div class="sign-in-field__input-wrap">
                    <img
                      class="sign-in-field__icon si-icon--light"
                      src="assets/sign-in/password-light.svg"
                      alt=""
                      width="21"
                      height="21"
                    />
                    <img
                      class="sign-in-field__icon si-icon--dark"
                      src="assets/sign-in/password.svg"
                      alt=""
                      width="21"
                      height="21"
                    />
                    <input
                      class="sign-in-field__input"
                      type="password"
                      id="password_new"
                      name="ResetPasswordForm[password]"
                      placeholder="password"
                      autocomplete="new-password"
                      required
                    />
                    <button
                      type="button"
                      class="sign-in-field__toggle"
                      aria-label="Toggle password visibility"
                      data-password-toggle
                    >
                      <img
                        class="si-icon--light"
                        src="assets/sign-in/eye-off-light.svg"
                        alt=""
                        width="21"
                        height="21"
                        data-eye-icon
                      />
                      <img
                        class="si-icon--dark"
                        src="assets/sign-in/eye-off.svg"
                        alt=""
                        width="21"
                        height="21"
                        data-eye-icon
                      />
                    </button>
                  </div>
                </div>

                <div class="sign-in-field">
                  <label class="sign-in-field__label" for="password_confirm">
                    Confirm Password
                  </label>
                  <div class="sign-in-field__input-wrap">
                    <img
                      class="sign-in-field__icon si-icon--light"
                      src="assets/sign-in/password-light.svg"
                      alt=""
                      width="21"
                      height="21"
                    />
                    <img
                      class="sign-in-field__icon si-icon--dark"
                      src="assets/sign-in/password.svg"
                      alt=""
                      width="21"
                      height="21"
                    />
                    <input
                      class="sign-in-field__input"
                      type="password"
                      id="password_confirm"
                      name="ResetPasswordForm[password_again]"
                      placeholder="confirm password"
                      autocomplete="new-password"
                      required
                    />
                    <button
                      type="button"
                      class="sign-in-field__toggle"
                      aria-label="Toggle confirm password visibility"
                      data-password-toggle
                    >
                      <img
                        class="si-icon--light"
                        src="assets/sign-in/eye-off-light.svg"
                        alt=""
                        width="21"
                        height="21"
                        data-eye-icon
                      />
                      <img
                        class="si-icon--dark"
                        src="assets/sign-in/eye-off.svg"
                        alt=""
                        width="21"
                        height="21"
                        data-eye-icon
                      />
                    </button>
                  </div>
                </div>
              </div>
            </div>

            <div class="sign-in-form__footer">
              <input type="hidden" name="_csrf" value="{{ csrftoken }}">
              <button
                type="submit"
                class="sign-in-btn sign-in-btn--primary sign-in-btn--full"
              >
                Submit Now
              </button>
            </div>
          </form>
        </div>
      </div>

      <div class="sign-in-image-side">
        <div class="sign-in-hero">
          <img
            src="assets/sign-in/subtract.svg"
            alt=""
            class="sign-in-hero__bg"
          />
          <img
            src="assets/sign-in/hero-image.png"
            alt="Set new password"
            class="sign-in-hero__img"
          />
          <a href="{{ page_url('signin') }}" class="sign-in-back">
            <span class="sign-in-back__icon" aria-hidden="true">
              <img
                class="sign-in-back__icon-img--light"
                src="assets/sign-in/arrow-back-light.svg"
                alt=""
                width="28"
                height="28"
              />
              <img
                class="sign-in-back__icon-img--dark"
                src="assets/sign-in/arrow-back.svg"
                alt=""
                width="28"
                height="28"
              />
            </span>
            <span class="sign-in-back__label">Back</span>
          </a>
          <div class="sign-in-trust">
            <div class="sign-in-trust__avatars">
              <img src="assets/images/avatar-1.png" alt="" width="24" height="24" class="sign-in-trust__avatar" />
              <img src="assets/images/avatar-2.png" alt="" width="24" height="24" class="sign-in-trust__avatar" />
              <img src="assets/images/avatar-3.png" alt="" width="24" height="24" class="sign-in-trust__avatar" />
              <img src="assets/images/avatar-4.png" alt="" width="24" height="24" class="sign-in-trust__avatar" />
            </div>
            <p class="sign-in-trust__text">Satisfied Clients in HQ Promo</p>
          </div>
        </div>
      </div>
    </div>
  </div>
{% endif %}

{% if site['captcha'] %}
  <script src="https://www.google.com/recaptcha/api.js?hl={{ site['iso_lang_code'] }}"></script>
{% endif %}
