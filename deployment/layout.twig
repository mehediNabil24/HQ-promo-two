<!DOCTYPE html>
<html lang="{{ site['iso_lang_code'] }}">
	<head>
		<meta charset="utf-8">
		<meta http-equiv="X-UA-Compatible" content="IE=edge">
		<meta name="viewport" content="width=device-width, initial-scale=1">
		<title>{{ page['title'] }}</title>
		<meta name="keywords" content="{{ site['seo_key'] }}">
		<meta name="description" content="{{ site['seo_desc'] }}">
		{% if site['favicon'] %}
			<link rel="shortcut icon" type="image/ico" href="{{ site['favicon'] }}"/>
		{% endif %}

		<!-- HTML5 shim and Respond.js for IE8 support of HTML5 elements and media queries -->
		<!--[if lt IE 9]>
		  <script src="https://oss.maxcdn.com/html5shiv/3.7.3/html5shiv.min.js"></script>
		  <script src="https://oss.maxcdn.com/respond/1.4.2/respond.min.js"></script>
		<![endif]-->
		{{ site['custom_header'] }}

		{# Perfect Panel loads Bootstrap + css/style.css (and other theme assets) here #}
		{% for style in site['styles'] %}
			<link rel="stylesheet" type="text/css" href="{{ style['href'] }}">
		{% endfor %}

		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet">
		<script src="https://code.iconify.design/iconify-icon/2.1.0/iconify-icon.min.js"></script>

		<script>
			window.modules = {};
		</script>
	</head>

	{% if user['auth'] %}
	<body class="dash-page">
		<div class="dash-shell d-flex">
			{# ===== Sidebar ===== #}
			<aside class="dash-sidebar flex-shrink-0" aria-label="Dashboard navigation">
				<div class="dash-sidebar__top">
					<a class="dash-sidebar__logo d-inline-flex" href="{{ page_url('index') }}" aria-label="{{ site['name'] }} home">
						{% if site['logo'] %}
							<img src="{{ site['logo'] }}" alt="{{ site['name'] }}" width="64" height="64">
						{% else %}
							<span class="dash-sidebar__logo-text">{{ site['name'] }}</span>
						{% endif %}
					</a>
					<button class="dash-notify btn" type="button" aria-label="Notifications">
						<img class="dash-notify__icon" src="assets/dashboard/notification-icon.png" alt="" width="24" height="24">
						<span class="dash-notify__dot" aria-hidden="true"></span>
					</button>
				</div>

				<div class="dash-profile gradient-border card border-0 w-100">
					<div class="card-body d-flex flex-column align-items-center text-center gap-2">
						<div class="dash-profile__avatar">
							<img
								src="{% if user['avatar'] %}{{ user['avatar'] }}{% else %}assets/dashboard/profile-pic.jpg{% endif %}"
								alt="{{ user['username']|default('Customer profile') }}"
								width="76"
								height="70"
							>
						</div>
						<p class="dash-profile__name mb-0">{{ user['username']|default('[Customer Name]') }}</p>
						<div class="dash-profile__balance d-flex align-items-stretch gap-1 w-100 justify-content-center">
							<span class="dash-profile__amount">{{ user.balance_formatted }}</span>
							<a
								class="dash-profile__add gradient-border btn p-0"
								href="{{ page_url('addfunds') }}"
								aria-label="Add funds"
							>
								<iconify-icon icon="ic:baseline-plus" width="18" height="18"></iconify-icon>
							</a>
						</div>
					</div>
				</div>

				<nav class="dash-nav w-100" aria-label="Order and services">
					<div class="dash-nav__section">
						<button
							class="dash-nav__heading"
							type="button"
							data-bs-toggle="collapse"
							data-bs-target="#navOrderServices"
							aria-expanded="true"
							aria-controls="navOrderServices"
						>
							<span>ORDER &amp; SERVICES</span>
							<iconify-icon class="dash-nav__chevron" icon="mdi:menu-up" width="20" height="20"></iconify-icon>
						</button>
						<div class="collapse show" id="navOrderServices">
							<ul class="dash-nav__list list-unstyled mb-0">
								{% for menu in site['menu'] %}
									<li>
										<a
											class="dash-nav__link{% if menu['active'] %} is-active{% endif %}"
											href="{{ menu['link'] }}"
											{% if menu['external'] %} target="_blank"{% endif %}
										>
											{% if menu['icon'] %}
												<i class="{{ menu['icon'] }}" aria-hidden="true"></i>
											{% else %}
												<iconify-icon icon="mdi:circle-outline" width="24" height="24"></iconify-icon>
											{% endif %}
											<span>{{ menu['name'] }}</span>
										</a>
									</li>
								{% endfor %}
							</ul>
						</div>
					</div>
				</nav>
			</aside>

			<button
				class="dash-sidebar-edge-toggle d-none d-lg-inline-flex"
				type="button"
				data-dash-sidebar-edge-toggle
				aria-label="Toggle sidebar"
				aria-expanded="true"
			>
				<img src="assets/dashboard/sidebar-toggle.svg" alt="" width="16" height="16" aria-hidden="true">
			</button>

			{# ===== Main ===== #}
			<div class="dash-content flex-grow-1 min-w-0 d-flex flex-column">
				<header class="dash-header d-flex align-items-center justify-content-between">
					<div class="d-flex align-items-center gap-3">
						<button
							class="dash-sidebar-toggle btn d-lg-none p-0"
							type="button"
							data-dash-sidebar-toggle
							aria-label="Toggle sidebar"
						>
							<iconify-icon icon="mdi:menu" width="24" height="24"></iconify-icon>
						</button>
						<div class="dash-header__title d-flex align-items-center gap-2">
							<iconify-icon
								class="dash-header__title-icon"
								icon="mdi:view-dashboard-outline"
								width="24"
								height="24"
							></iconify-icon>
							<span>{{ page['title'] }}</span>
						</div>
					</div>

					<div class="dash-header__actions d-flex align-items-center gap-2">
						{# Currency / balance switcher #}
						<div class="dropdown">
							<button
								class="dash-wallet btn"
								type="button"
								id="dashCurrencyMenu"
								data-bs-toggle="dropdown"
								data-bs-display="static"
								data-bs-auto-close="true"
								aria-expanded="false"
								aria-label="Currency"
							>
								<span class="dash-wallet__icon" aria-hidden="true">
									<iconify-icon icon="mdi:wallet" width="14" height="14"></iconify-icon>
								</span>
								<span class="dash-wallet__amount" data-dash-currency-amount>{{ user.balance_formatted }}</span>
								<iconify-icon icon="mdi:chevron-down" width="18" height="18"></iconify-icon>
							</button>
							<ul class="dash-profile-menu dropdown-menu dropdown-menu-end" aria-labelledby="dashCurrencyMenu" id="currencies-list">
								{% if site.currencies %}
									{% for key, rate in site.currencies %}
										<li>
											<button
												class="dash-profile-menu__link{% if loop.first %} is-accent{% endif %}"
												type="button"
												id="currencies-item"
												data-dash-currency="{{ key }}"
												data-dash-currency-symbol="{{ rate.symbol }}"
												data-rate-key="{{ key }}"
												data-rate-symbol="{{ rate.symbol }}"
											>
												{{ key }} {{ rate.symbol }}
											</button>
										</li>
									{% endfor %}
								{% else %}
									<li>
										<button class="dash-profile-menu__link is-accent" type="button" data-dash-currency="USD" data-dash-currency-symbol="$">USD</button>
									</li>
									<li>
										<button class="dash-profile-menu__link" type="button" data-dash-currency="EUR" data-dash-currency-symbol="€">EUR</button>
									</li>
								{% endif %}
							</ul>
						</div>

						{# Theme toggle #}
						<button
							class="theme-toggle"
							type="button"
							data-theme-toggle
							aria-pressed="false"
							aria-label="Switch to dark theme"
						>
							<span class="theme-toggle__track" aria-hidden="true"></span>
							<span class="theme-toggle__label" data-theme-label>Light</span>
							<span class="theme-toggle__thumb" aria-hidden="true">
								<img
									class="theme-toggle__icon theme-toggle__icon--light"
									src="assets/icons/theme-thumb.svg"
									alt=""
									width="32"
									height="32"
								>
								<span class="theme-toggle__icon theme-toggle__icon--dark" aria-hidden="true">
									<iconify-icon icon="ph:moon-fill" width="20" height="20"></iconify-icon>
								</span>
							</span>
						</button>

						{# Notifications #}
						<button class="dash-notify btn" type="button" aria-label="Notifications">
							<img class="dash-notify__icon" src="assets/dashboard/notification-icon.png" alt="" width="24" height="24">
							<span class="dash-notify__dot" aria-hidden="true"></span>
						</button>

						{# Profile / account menu #}
						<div class="dropdown">
							<button
								class="dash-user btn"
								type="button"
								id="dashProfileMenu"
								data-bs-toggle="dropdown"
								data-bs-display="static"
								data-bs-auto-close="true"
								aria-expanded="false"
								aria-label="Account menu"
							>
								<img
									class="dash-user__avatar rounded-circle"
									src="{% if user['avatar'] %}{{ user['avatar'] }}{% else %}assets/dashboard/profile-pic.jpg{% endif %}"
									alt=""
									width="30"
									height="30"
								>
								<iconify-icon icon="mdi:chevron-down" width="18" height="18"></iconify-icon>
							</button>
							<ul class="dash-profile-menu dropdown-menu dropdown-menu-end" aria-labelledby="dashProfileMenu">
								{% for menu in site['account_menu'] %}
									{% if menu['link'] %}
										<li>
											<a
												class="dash-profile-menu__link{% if menu['active'] %} is-accent{% endif %}"
												href="{{ menu['link'] }}"
												{% if menu['external'] %} target="_blank"{% endif %}
											>
												{{ menu['name'] }}
											</a>
										</li>
									{% endif %}
								{% else %}
									<li>
										<a class="dash-profile-menu__link is-accent" href="{{ page_url('account') }}">My Account</a>
									</li>
									<li>
										<a class="dash-profile-menu__link" href="{{ page_url('index') }}">Dashboard</a>
									</li>
									<li>
										<a class="dash-profile-menu__link" href="{{ page_url('api') }}">API</a>
									</li>
									<li>
										<a class="dash-profile-menu__link is-logout" href="{{ page_url('logout') }}">
											<iconify-icon icon="heroicons-outline:logout" width="20" height="20"></iconify-icon>
											<span>Log Out</span>
										</a>
									</li>
								{% endfor %}
							</ul>
						</div>
					</div>
				</header>

				<main class="dash-main flex-grow-1">
					{{ content }}
				</main>
			</div>
		</div>

		<div class="dash-sidebar-backdrop" data-dash-sidebar-backdrop hidden></div>

		{# Notifications wrapper (Perfect Panel) #}
		<div id="notify-wrapper" class="alert alert-success hidden" style="display: none;"></div>

		{{ site['custom_footer'] }}

		{# Perfect Panel loads Bootstrap JS + js/main.js (and other theme scripts) here #}
		{% for script in site['scripts'] %}
			<script type="text/javascript" {% if script['src'] %} src="{{ script['src'] }}" {% endif %}>
				{% if script['code'] %}
{{ script['code'] }}
{% endif %}
			</script>
		{% endfor %}
	</body>

	{% else %}
	{# ===== Guest / public layout (Perfect Panel default nav) ===== #}
	<body>
		<nav class="navbar navbar-default navbar-static-top {% if site['rtl'] %} rtl-navbar {% endif %}">
			<div class="container">
				<div class="navbar-header">
					<button type="button" class="navbar-toggle collapsed" data-toggle="collapse" data-target="#navbar" aria-expanded="false" aria-controls="navbar">
						<span class="sr-only">Toggle navigation</span>
						<span class="icon-bar"></span>
						<span class="icon-bar"></span>
						<span class="icon-bar"></span>
					</button>
					<a class="navbar-brand" href="{{ page_url('index') }}">
						{% if site['logo'] %}
							<img src="{{ site['logo'] }}" alt="{{ site['name'] }}" title="">
						{% else %}
							{{ site['name'] }}
						{% endif %}
					</a>
				</div>
				<div id="navbar" class="collapse navbar-collapse">
					{% if site['languages']|length > 1 %}
						<ul class="nav navbar-nav navbar-left-block">
							<li class="dropdown">
								{% for lang in site['languages'] %}
									{% if lang['active'] %}
										<a href="#" class="dropdown-toggle" data-toggle="dropdown" role="button" aria-haspopup="true" aria-expanded="false">
											{{ lang['name'] }}
											<span class="caret"></span>
										</a>
									{% endif %}
								{% endfor %}
								<ul class="dropdown-menu dropdown-max-height">
									{% for lang in site['languages'] %}
										<li {% if lang['active'] %} class="active" {% endif %}>
											<a href="{{ lang['url'] }}">{{ lang['name'] }}</a>
										</li>
									{% endfor %}
								</ul>
							</li>
						</ul>
					{% endif %}
					<ul class="nav navbar-nav navbar-right">
						{% for menu in site['menu'] %}
							<li {% if menu['active'] %} class="active" {% endif %}>
								<a href="{{ menu['link'] }}" {% if menu['external'] %} target="_blank" {% endif %}>
									{% if menu['icon'] %}
										<i class="navbar-icon {{ menu['icon'] }}"></i>
									{% endif %}
									{{ menu['name'] }}
								</a>
							</li>
						{% endfor %}
					</ul>
				</div>
			</div>
		</nav>

		{{ content }}

		<div id="notify-wrapper" class="alert alert-success hidden" style="display: none;"></div>

		{{ site['custom_footer'] }}

		{% for script in site['scripts'] %}
			<script type="text/javascript" {% if script['src'] %} src="{{ script['src'] }}" {% endif %}>
				{% if script['code'] %}
{{ script['code'] }}
{% endif %}
			</script>
		{% endfor %}
	</body>
	{% endif %}
</html>
