<script>
(function () {
  function whenJQuery(fn) {
    if (window.jQuery) {
      fn(window.jQuery);
      return;
    }
    var tries = 0;
    var timer = window.setInterval(function () {
      tries += 1;
      if (window.jQuery) {
        window.clearInterval(timer);
        fn(window.jQuery);
      } else if (tries > 100) {
        window.clearInterval(timer);
      }
    }, 50);
  }

  whenJQuery(function ($) {
    var $tabs = $("[data-order-platform-script]");
    var $category = $("#orderform-category");
    var $searchInput = $("#template-input");
    if (!$tabs.length || !$category.length) return;

    var fullCache = null;
    var filtering = false;

    function resolvePlatform(name) {
      var value = String(name || "").toLowerCase().trim();
      if (value.indexOf("facebook") !== -1) return "facebook";
      if (value.indexOf("instagram") !== -1) return "instagram";
      if (
        value.indexOf("twitter") !== -1 ||
        value.indexOf("x /") !== -1 ||
        value.indexOf("x (") !== -1 ||
        value === "x" ||
        value.indexOf(" x ") !== -1
      ) {
        return "twitter";
      }
      if (value.indexOf("youtube") !== -1 || value.indexOf("youtu") !== -1) return "youtube";
      if (value.indexOf("tiktok") !== -1 || value.indexOf("tik tok") !== -1) return "tiktok";
      if (value.indexOf("linkedin") !== -1) return "linkedin";
      if (value.indexOf("telegram") !== -1) return "telegram";
      if (value.indexOf("discord") !== -1) return "discord";
      if (value.indexOf("spotify") !== -1) return "spotify";
      if (value.indexOf("soundcloud") !== -1) return "soundcloud";
      if (value.indexOf("snapchat") !== -1) return "snapchat";
      if (value.indexOf("traffic") !== -1 || value.indexOf("website") !== -1) return "traffic";
      return "other";
    }

    function buildCacheFromSelect() {
      var items = [];
      $category.find("option").each(function () {
        var $opt = $(this);
        items.push({
          value: String($opt.attr("value") || ""),
          text: $.trim($opt.text()),
          platform: $opt.attr("data-platform") || resolvePlatform($opt.text()),
          icon: $opt.attr("data-icon") || ""
        });
      });
      return items.length ? items : null;
    }

    function ensureCache() {
      if (!fullCache || !fullCache.length) {
        fullCache = buildCacheFromSelect();
      } else if ($category.find("option").length > fullCache.length) {
        fullCache = buildCacheFromSelect();
      }
      return fullCache;
    }

    function formatSelect2(state) {
      if (!state.id) return state.text;
      var icon = $(state.element).attr("data-icon");
      if (!icon) return state.text;
      return $('<span class="dash-select2-option"></span>')
        .append(icon)
        .append($('<span class="dash-select2-option__text"></span>').text(state.text));
    }

    function reinitSelect2($el) {
      if (!$el.length || !$.fn.select2) return;
      if ($el.hasClass("select2-hidden-accessible")) {
        try {
          $el.select2("destroy");
        } catch (e) {}
      }
      if ($el.attr("data-select") !== "true") return;

      var opts = {
        width: "100%",
        templateResult: formatSelect2,
        templateSelection: formatSelect2,
        escapeMarkup: function (markup) {
          return markup;
        }
      };
      if ($el.attr("data-select-search") === "true") {
        opts.minimumResultsForSearch = 0;
      }
      if ($el.attr("data-select-dir")) {
        opts.dir = $el.attr("data-select-dir");
      }
      $el.select2(opts);
    }

    function fillOptions(source, selectedValue) {
      var hadSelect2 = $category.hasClass("select2-hidden-accessible");
      if (hadSelect2) {
        try {
          $category.select2("destroy");
        } catch (e) {}
      }

      $category.empty();
      $.each(source, function (_, item) {
        var $opt = $("<option></option>")
          .attr("value", item.value)
          .attr("data-platform", item.platform)
          .text(item.text);
        if (item.icon) $opt.attr("data-icon", item.icon);
        $category.append($opt);
      });

      var next = String(selectedValue || "");
      if (!next || !$category.find('option[value="' + next.replace(/"/g, '\\"') + '"]').length) {
        next = source[0] ? source[0].value : "";
      }

      filtering = true;
      $category.val(next).trigger("change");
      filtering = false;

      // Re-apply Select2 on category only; Perfect Panel refreshes the service select
      window.setTimeout(function () {
        reinitSelect2($category);
      }, 40);
    }

    function filterByPlatform(platform, selectFirst) {
      var cache = ensureCache();
      if (!cache || !platform) return false;

      var matches = $.grep(cache, function (item) {
        return item.platform === platform;
      });
      var source = matches.length ? matches : cache;
      var prev = String($category.val() || "");
      var next = selectFirst
        ? source[0] && source[0].value
        : ($.grep(source, function (item) {
            return item.value === prev;
          }).length
            ? prev
            : source[0] && source[0].value);

      fillOptions(source, next);
      return Boolean(matches.length);
    }

    function restoreAllCategories(keepSelection) {
      var cache = ensureCache();
      if (!cache) return;
      var prev = keepSelection ? String($category.val() || "") : "";
      fillOptions(cache, prev);
    }

    function setActiveTab($tab) {
      if (!$tab || !$tab.length) return;
      $tabs.find(".platform-tab").each(function () {
        var on = this === $tab.get(0);
        $(this).toggleClass("is-active", on).attr("aria-selected", on ? "true" : "false");
      });
      syncPolygons();
    }

    function syncPolygons() {
      var dark = document.documentElement.getAttribute("data-theme") === "dark";
      $tabs.find(".platform-tab").each(function () {
        var $img = $(this).find(".platform-tab__polygon");
        if (!$img.length) return;
        var src = String($img.attr("src") || "");
        var slash = src.lastIndexOf("/");
        if (slash === -1) return;
        var dir = src.slice(0, slash + 1);
        var active = $(this).hasClass("is-active");
        $img.attr(
          "src",
          dir + (!dark || active ? "polygon.svg" : "polygon-dark.svg")
        );
      });
    }

    function syncTabToSelectedCategory() {
      if (filtering) return;
      var $selected = $category.find("option:selected").first();
      if (!$selected.length) return;
      var platform =
        $selected.attr("data-platform") || resolvePlatform($selected.text());
      var $tab = $tabs.find('.platform-tab[data-platform="' + platform + '"]').first();
      if ($tab.length) setActiveTab($tab);
    }

    function hideEmptyPlatformTabs() {
      var cache = ensureCache();
      if (!cache) return;
      $tabs.find(".platform-tab[data-platform]").each(function () {
        var platform = $(this).attr("data-platform");
        var has = $.grep(cache, function (item) {
          return item.platform === platform;
        }).length;
        $(this).toggle(Boolean(has));
      });
    }

    $tabs.on("click", ".platform-tab[data-platform]", function (event) {
      event.preventDefault();
      var $tab = $(this);
      setActiveTab($tab);
      filterByPlatform(String($tab.attr("data-platform") || ""), true);
    });

    // Search needs the full category list so Perfect Panel can jump to any service
    $searchInput.on("focus", function () {
      restoreAllCategories(true);
    });

    $category.on("change select2:select", syncTabToSelectedCategory);

    var bootTries = 0;
    var bootTimer = window.setInterval(function () {
      bootTries += 1;
      if ($category.find("option").length) {
        window.clearInterval(bootTimer);
        ensureCache();
        hideEmptyPlatformTabs();

        var $active = $tabs.find(".platform-tab.is-active:visible").first();
        if (!$active.length) {
          $active = $tabs.find(".platform-tab[data-platform]:visible").first();
        }
        if ($active.length) {
          setActiveTab($active);
          filterByPlatform(String($active.attr("data-platform") || ""), true);
        } else {
          syncTabToSelectedCategory();
        }
      } else if (bootTries >= 60) {
        window.clearInterval(bootTimer);
      }
    }, 100);
  });
})();
</script>
